TG_API_ID=
TG_API_HASH=
# Optional session string to skip future logins
TG_SESSION=

# Optional non-interactive first login
TG_PHONE_NUMBER=
TG_PASSWORD=
TG_PHONE_CODE=

# Groq API key — powers both Whisper transcription and the groq/compound text AI.
# Get one at https://console.groq.com/keys (starts with gsk_).
GROQ_API_KEY=
# Optional transcription model override (default: whisper-large-v3; use whisper-large-v3-turbo for lower cost/latency)
WHISPER_MODEL=whisper-large-v3
# Optional: pin transcription to one ISO-639-1 language (e.g. ru, en).
# Leave empty to auto-detect the language per message (multilingual).
WHISPER_LANGUAGE=

# Optional Groq text model for AI commands (/ai, /tldr, /summary) — default: groq/compound
GROQ_TEXT_MODEL=groq/compound

# Comma-separated Telegram peer IDs to auto-transcribe voice messages in (besides private chats)
AUTO_TRANSCRIBE_PEER_IDS=
# Comma-separated Telegram peer IDs where auto-transcription is disabled
TRANSCRIBE_DISABLED_PEER_IDS=

# Deployment (normally pulled from rcli tool secrets)
DOCKER_IMAGE=readyk/tg-userbot
DEPLOY_HOST=
DEPLOY_PATH=/root/tg-userbot
